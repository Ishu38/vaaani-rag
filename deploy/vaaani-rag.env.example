# /etc/vaaani-rag/env  — read by systemd via EnvironmentFile=
#
# Copy this file to /etc/vaaani-rag/env on the VPS, fill in real values,
# then `chmod 600` it. Never check the live file into git.
#
# Format note: systemd's EnvironmentFile is shell-like KEY=VALUE per line —
# no `export`, no `$VAR` substitution, no quotes unless they're part of the
# literal value.

# ---- core LLM ----
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- auth ----
# Generate once with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Keep this stable across restarts — rotating it invalidates every session cookie.
JWT_SECRET=replace-with-64-byte-token-urlsafe
COOKIE_SECURE=1
APP_BASE_URL=https://brain.vaaani.in

# ---- GitHub OAuth ----
# In GitHub OAuth App settings, add this callback URL alongside the dev one:
#   https://brain.vaaani.in/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://brain.vaaani.in/auth/github/callback

# ---- Google OAuth (optional; button hidden until both vars set) ----
# Add https://brain.vaaani.in/auth/google/callback to the OAuth client's
# Authorized redirect URIs in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://brain.vaaani.in/auth/google/callback

# ---- SMTP for verification emails (optional) ----
# Without SMTP_HOST set, verification links print to `journalctl -u vaaani-rag`.
# Reuse the same SMTP creds Vaani CAVP uses (Resend / Hostinger / Gmail App Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vaaani <no-reply@vaaani.in>
SMTP_USE_TLS=1
